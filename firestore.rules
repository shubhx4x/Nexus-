rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'gamechangers4200@gmail.com' ||
        request.auth.token.email == 'developer@nexus.app' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer')
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.role != 'developer' || request.auth.token.email == 'gamechangers4200@gmail.com' || request.auth.token.email == 'developer@nexus.app');
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'themeColor', 'interfaceMode', 'isPrivate', 'dndMode', 'status', 'lastSeen', 'updatedAt'])
      ) || isAdmin();
    }

    // Username Registry
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAdmin();
    }

    // Conversations
    match /conversations/{convId} {
      function isParticipant() { 
        return isSignedIn() && request.auth.uid in resource.data.participants; 
      }
      
      allow read: if isParticipant() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.participants is list && request.auth.uid in request.resource.data.participants;
      allow update: if isParticipant() || isAdmin();
    }

    // Messages
    match /conversations/{convId}/messages/{msgId} {
      function isMember() {
        return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
      
      allow read: if isMember() || isAdmin();
      allow create: if isMember() && request.resource.data.senderId == request.auth.uid;
      allow update: if isMember() && (
        // Only allow unsend or read receipt update
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['isUnsent', 'readBy', 'deletedBy'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Stories
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && (
        isOwner(resource.data.userId) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount'])
      )) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }

    // Follows
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isOwner(resource.data.followerId) || isAdmin();
    }

    // Requests
    match /requests/{requestId} {
      allow read: if isOwner(resource.data.fromId) || isOwner(resource.data.toId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update: if isOwner(resource.data.toId) || isAdmin();
      allow delete: if isOwner(resource.data.fromId) || isOwner(resource.data.toId) || isAdmin();
    }

    // Music Registry
    match /music/{musicId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // System Announcements
    match /announcements/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
